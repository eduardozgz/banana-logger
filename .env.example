# Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GENERAL
# =============================================================================

# Node environment (development, production, test)
NODE_ENV=production

# Log level for application logging (error, warn, info, debug)
LOG_LEVEL=info

PUBLIC_URL=http://localhost

# =============================================================================
# DISCORD BOT
# =============================================================================

# Discord bot token for the specific bot instance
DISCORD_BOT_INSTANCE_TOKEN=your_discord_bot_token_here

# Discord application client ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Whether to deploy slash commands on bot startup (true/false or a guild id to deploy there)
DISCORD_BOT_INSTANCE_DEPLOY_COMMANDS=true

# =============================================================================
# REST PROXY (optional)
# =============================================================================

# Shared Discord REST proxy (@bl/rest-proxy). When set, the bot routes all REST
# through it so one rate limiter owns the token's global budget — recommended
# when running multiple shards/processes on the same token. Leave unset to have
# the bot talk to Discord directly.
# In the docker-compose stack, point it at the bundled service:
# DISCORD_BOT_INSTANCE_REST_PROXY_URL=http://rest-proxy:8765/api

# Port the proxy listens on (defaults to 8765)
# REST_PROXY_PORT=8765

# =============================================================================
# DATABASE
# =============================================================================

# Database connection URL (MongoDB)
# Example: mongodb://localhost:27017/bananaLogger?replicaSet=rs0&directConnection=true
DATABASE_URL='mongodb://mongo:27017/bananaLogger?replicaSet=rs0&directConnection=true'

# =============================================================================
# REDIS
# =============================================================================

# Redis connection URL
# Example: redis://localhost:6379
# Example with auth: redis://username:password@localhost:6379
REDIS_URL=redis://redis:6379

# =============================================================================
# IMG service
# =============================================================================

IMG_PORT=3000
# No trailing slash: templates build the swatch URL as {IMG_PUBLIC_URL}/color/...
# and a trailing slash here yields a //color/... path the img service 404s on.
IMG_PUBLIC_URL=http://localhost:3000