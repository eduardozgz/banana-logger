{
  "name": "@/bot",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "build": "tsup-node",
    "dev": "pnpm with-env pnpm build --watch . --watch ../../packages --onSuccess \"node dist/index.js\"",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env node ./dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "devDependencies": {
    "@/eslint-config": "workspace:*",
    "@/prettier-config": "workspace:*",
    "@/tsconfig": "workspace:*",
    "@total-typescript/ts-reset": "catalog:",
    "@types/lodash": "^4.17.24",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:eslint",
    "prettier": "catalog:prettier",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.2"
  },
  "prettier": "@/prettier-config",
  "dependencies": {
    "@/common": "workspace:*",
    "@/db": "workspace:*",
    "@/i18n": "workspace:*",
    "@/logger": "workspace:*",
    "@/redis": "workspace:*",
    "@discordjs/builders": "catalog:discord",
    "@formatjs/intl-durationformat": "^0.10.3",
    "@t3-oss/env-core": "catalog:",
    "@twemoji/api": "^17.0.2",
    "bufferutil": "catalog:",
    "discord-api-types": "catalog:discord",
    "discord.js": "catalog:discord",
    "lodash": "^4.18.1",
    "utf-8-validate": "catalog:",
    "zod": "catalog:"
  }
}
