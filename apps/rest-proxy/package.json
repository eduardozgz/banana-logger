{
  "name": "@bl/rest-proxy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsup-node",
    "dev": "pnpm with-env pnpm build --watch . --onSuccess \"pnpm run start\"",
    "start": "pnpm with-env node --enable-source-maps dist/index.js",
    "clean": "rm -rf .turbo node_modules dist",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@bl/logger": "workspace:*",
    "@discordjs/proxy": "^2.1.1",
    "@discordjs/rest": "^2.6.0",
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bl/eslint-config": "workspace:*",
    "@bl/prettier-config": "workspace:*",
    "@bl/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:eslint",
    "prettier": "catalog:prettier",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "prettier": "@bl/prettier-config"
}
